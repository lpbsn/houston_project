# Shared-dev template — copy to .env.shared-dev and fill from 1Password (never commit .env.shared-dev).
# See docs/engineering/shared_dev_database.md for setup, aligned secrets, and limitations.

HOUSTON_DEV_DB_MODE=shared

# Remote PostgreSQL — POSTGRES_HOST must NOT be "postgres" (that is the local Compose service name).
POSTGRES_HOST=your-host.example.com
POSTGRES_PORT=5432
POSTGRES_DB=houston_dev_collab
POSTGRES_USER=houston
POSTGRES_PASSWORD=replace-me
POSTGRES_SSLMODE=require

DJANGO_SECRET_KEY=replace-me-shared-team-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Must match across all shared-dev developers (1Password team vault).
HOUSTON_AUTH_TOKEN_PEPPER: ${HOUSTON_AUTH_TOKEN_PEPPER:-}
HOUSTON_REGISTRATION_INVITE_CODES=dev-invite-shared

# Redis/Celery stay local Docker — not shared between developers.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
VITE_API_BASE_URL=http://localhost:8000

# Auth throttling (public auth mutation endpoints)
HOUSTON_AUTH_THROTTLE_ENABLED=true
HOUSTON_CACHE_REDIS_URL=
HOUSTON_THROTTLE_AUTH_LOGIN=
HOUSTON_THROTTLE_AUTH_REFRESH=
HOUSTON_THROTTLE_AUTH_REGISTER=
HOUSTON_THROTTLE_AUTH_REGISTER_VALIDATE=
HOUSTON_THROTTLE_AUTH_INVITATION_ACCEPT=

HOUSTON_DIRECTOR_INVITATION_TTL_DAYS=7

# Onboarding AI (server-only; never expose in VITE_* or frontend env)
OPENAI_API_KEY=

HOUSTON_AI_OBSERVATION_PROVIDER=openai
HOUSTON_AI_OBSERVATION_MODEL=gpt-4.1-mini
HOUSTON_AI_OBSERVATION_TIMEOUT_SECONDS=30
HOUSTON_AI_OBSERVATION_MAX_RETRIES=2

HOUSTON_PRIVATE_MEDIA_ROOT=
HOUSTON_TEMPORARY_UPLOAD_TTL_HOURS=24
HOUSTON_OBSERVATION_PHOTO_MAX_BYTES=10485760
HOUSTON_TRANSCRIPTION_AUDIO_MAX_BYTES=10485760
HOUSTON_AI_TRANSCRIPTION_PROVIDER=openai
HOUSTON_AI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
HOUSTON_AI_TRANSCRIPTION_TIMEOUT_SECONDS=10
HOUSTON_AI_TRANSCRIPTION_PROMPT_VERSION=ai_transcription_v1
