DJANGO_SECRET_KEY=replace-me-for-local-dev
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
POSTGRES_DB=houston
POSTGRES_USER=houston
POSTGRES_PASSWORD=houston
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
VITE_API_BASE_URL=http://localhost:8000

# Public onboarding registration (comma-separated invite codes; leave empty to disable)
HOUSTON_REGISTRATION_INVITE_CODES=
HOUSTON_DIRECTOR_INVITATION_TTL_DAYS=7

# Onboarding AI (server-only; never expose in VITE_* or frontend env)
OPENAI_API_KEY=
HOUSTON_AI_ONBOARDING_PROVIDER=openai
HOUSTON_AI_ONBOARDING_MODEL=gpt-4.1-mini
HOUSTON_AI_ONBOARDING_TIMEOUT_SECONDS=30
HOUSTON_AI_ONBOARDING_MAX_RETRIES=2
HOUSTON_AI_ONBOARDING_USE_STRICT_JSON_SCHEMA=1

# Phase 3 — private media + transcription (server-only)
HOUSTON_PRIVATE_MEDIA_ROOT=
HOUSTON_TEMPORARY_UPLOAD_TTL_HOURS=24
HOUSTON_OBSERVATION_PHOTO_MAX_BYTES=10485760
HOUSTON_TRANSCRIPTION_AUDIO_MAX_BYTES=10485760
HOUSTON_AI_TRANSCRIPTION_PROVIDER=openai
HOUSTON_AI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
HOUSTON_AI_TRANSCRIPTION_TIMEOUT_SECONDS=10
HOUSTON_AI_TRANSCRIPTION_PROMPT_VERSION=ai_transcription_v1
